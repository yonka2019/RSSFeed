# RSSFeed environment variables
#
# Copy this file to `.env.local` (git-ignored) and fill in real values.
# Every variable below is OPTIONAL for local development — the app falls back
# to the defaults shown here. For PRODUCTION you MUST override the secrets.

# --- Security (CHANGE THESE IN PRODUCTION) ---

# Password for the admin login.
# Default: "admin" — insecure, do not deploy with this.
ADMIN_PASSWORD=admin

# Secret used to sign sessions. Use a long random string in production.
# Default: "dev-secret-change-me" — publicly known, do not deploy with this.
SECRET_KEY=dev-secret-change-me

# --- Storage (MongoDB) ---

# MongoDB connection string. Point this at your local instance or Atlas cluster.
# Default: "mongodb://localhost:27017"
MONGODB_URI=mongodb://localhost:27017

# Database name to use within the MongoDB instance.
# Default: "rssfeed"
MONGODB_DB=rssfeed

# --- Site metadata ---

# Public base URL of the site. Used for canonical links and feed URLs.
# No trailing slash needed (it is stripped automatically).
# Default: "http://localhost:3000"
SITE_URL=http://localhost:3000

# Site title shown in the UI and feed metadata.
# Default: "RSSFeed"
SITE_TITLE=RSSFeed

# Site description used in metadata and feeds.
# Default: "A modern news feed with RSS, Atom and JSON."
SITE_DESCRIPTION=A modern news feed with RSS, Atom and JSON.

# Author name used in feed metadata.
# Default: "RSSFeed"
SITE_AUTHOR=RSSFeed
